{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "release",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/cmake/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "TRUMPET_RECREATE_ALL_GENERATED": "OFF",
        "CMAKE_CXX_COMPILER": "C:/msys64/mingw64/bin/g++.exe"
      }
    },
    {
      "name": "release-fresh",
      "inherits": "release",
      "cacheVariables": {
        "TRUMPET_RECREATE_ALL_GENERATED": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "trumpet-only",
      "configurePreset": "release",
      "targets": [
        "trumpet-only"
      ]
    },
    {
      "name": "full-build",
      "configurePreset": "release",
      "targets": [
        "full-build"
      ]
    },
    {
      "name": "full-build-fresh",
      "configurePreset": "release-fresh",
      "cleanFirst": true,
      "targets": [
        "full-build"
      ]
    },
    {
      "name": "basic-test",
      "configurePreset": "release",
      "targets": [
        "basic-test"
      ]
    }
  ]
}

